3) Once a log is found, get its name and use `mineBlock` to collect 4 logs.
4) If no log is found within 120 seconds, chat a failure message.

Code:
```javascript
// Helper function: exploreUntil
async function exploreUntil(bot, direction, maxTime = 60, callback) {
    const startTime = Date.now();
    const stepDistance = 10;
    while (Date.now() - startTime < maxTime * 1000) {
        // Check callback
        const result = callback();
        if (result) return result;

        // Move in the given direction
        const target = bot.entity.position.offset(
            direction.x * stepDistance,
            direction.y * stepDistance,
            direction.z * stepDistance
        );
        try {
            await bot.pathfinder.goto(new GoalNear(target.x, target.y, target.z, 1));
        } catch (err) {
            // If pathfinding fails, try a different offset
            const altTarget = bot.entity.position.offset(
                direction.x * stepDistance * -1,
                direction.y * stepDistance,
                direction.z * stepDistance * -1
            );
            await bot.pathfinder.goto(new GoalNear(altTarget.x, altTarget.y, altTarget.z, 1));
        }

        // Wait a bit before next check
        await bot.waitForTicks(20);
    }
    return null;
}

// Helper function: mineBlock (as provided)
async function mineBlock(bot, name, count = 1) {
    const blocks = bot.findBlocks({
        matching: (block) => {
            return block.name === name;
        },
        maxDistance: 32,
        count: count,
    });
    const targets = [];
    for (let i = 0; i < Math.min(blocks.length, count); i++) {
        targets.push(bot.blockAt(blocks[i]));
    }
    await bot.collectBlock.collect(targets, { ignoreNoPath: true });
}

// Main function
async function mineFourWoodLogs(bot) {
    bot.chat("Exploring to find a tree...");
    const logBlock = await exploreUntil(bot, new Vec3(1, 0, 1), 120, () => {
        const block = bot.findBlock({
            matching: (block) => block.name.endsWith("_log"),
            maxDistance: 32,
        });
        return block;
    });

    if (!logBlock) {
        bot.chat("Could not find any wood logs nearby.");
        return;
    }

    const logName = logBlock.name;
    bot.chat(`Found ${logName}, mining 4 logs...`);
    await mineBlock(bot, logName, 4);
    bot.chat("Successfully mined 4 wood logs.");
}
