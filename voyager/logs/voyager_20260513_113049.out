Code:
```javascript
async function mineWoodLogs(bot) {
    // Helper to get a random direction vector
    function randomDirection() {
        const choices = [-1, 0, 1];
        let x, y, z;
        do {
            x = choices[Math.floor(Math.random() * choices.length)];
            y = choices[Math.floor(Math.random() * choices.length)];
            z = choices[Math.floor(Math.random() * choices.length)];
        } while (x === 0 && y === 0 && z === 0);
        return new Vec3(x, y, z);
    }

    // Try up to 3 times with different random directions
    for (let attempt = 0; attempt < 3; attempt++) {
        const direction = randomDirection();
        bot.chat(`Exploring direction ${direction} to find a tree...`);
        const logBlock = await exploreUntil(bot, direction, 120, () => {
            const block = bot.findBlock({
                matching: (block) => block.name.endsWith("_log"),
                maxDistance: 32,
            });
            return block;
        });
        if (logBlock) {
            bot.chat(`Found ${logBlock.name}, mining 4 logs.`);
            await mineBlock(bot, logBlock.name, 4);
            bot.chat("Successfully mined 4 wood logs.");
            return;
        }
        bot.chat("No tree found in this direction, trying another...");
    }
    bot.chat("Failed to find any tree after 3 attempts.");
}
