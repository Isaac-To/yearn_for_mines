```javascript
// helper functions
function getRandomDirection() {
    const directions = [
        new Vec3(1, 0, 0),
        new Vec3(-1, 0, 0),
        new Vec3(0, 0, 1),
        new Vec3(0, 0, -1),
        new Vec3(1, 0, 1),
        new Vec3(1, 0, -1),
        new Vec3(-1, 0, 1),
        new Vec3(-1, 0, -1),
        new Vec3(0, 1, 0),
        new Vec3(0, -1, 0),
        new Vec3(1, 1, 0),
        new Vec3(1, -1, 0),
        new Vec3(-1, 1, 0),
        new Vec3(-1, -1, 0),
        new Vec3(0, 1, 1),
        new Vec3(0, 1, -1),
        new Vec3(0, -1, 1),
        new Vec3(0, -1, -1),
        new Vec3(1, 1, 1),
        new Vec3(1, 1, -1),
        new Vec3(1, -1, 1),
        new Vec3(1, -1, -1),
        new Vec3(-1, 1, 1),
        new Vec3(-1, 1, -1),
        new Vec3(-1, -1, 1),
        new Vec3(-1, -1, -1)
    ];
    return directions[Math.floor(Math.random() * directions.length)];
}

function isLogBlock(block) {
    return block.name.endsWith("_log");
}

async function mineWoodLogs(bot) {
    let logsNeeded = 4;
    while (logsNeeded > 0) {
        bot.chat(`Looking for a tree, need ${logsNeeded} more logs.`);
        const direction = getRandomDirection();
        const logBlock = await exploreUntil(bot, direction, 60, () => {
            const block = bot.findBlock({
                matching: (b) => isLogBlock(b),
                maxDistance: 32,
            });
            return block;
        });
        if (!logBlock) {
            bot.chat("Could not find any trees nearby.");
            break;
        }
        bot.chat(`Found ${logBlock.name}, mining up to ${logsNeeded} logs.`);
        // Count logs before mining
        const logsBefore = bot.inventory.items().filter(item => item.name.endsWith("_log")).reduce((sum, item) => sum + item.count, 0);
        await mineBlock(bot, logBlock.name, logsNeeded);
        // Count logs after mining
        const logsAfter = bot.inventory.items().filter(item => item.name.endsWith("_log")).reduce((sum, item) => sum + item.count, 0);
        const collected = logsAfter - logsBefore;
        logsNeeded -= collected;
        bot.chat(`Collected ${collected} logs, still need ${logsNeeded}.`);
    }
    if (logsNeeded > 0) {
        bot.chat(`Failed to collect all 4 logs. Still need ${logsNeeded}.`);
    } else {
        bot.chat("Successfully collected 4 wood logs.");
    }
}
```

