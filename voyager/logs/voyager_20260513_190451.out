4) Announce completion via chat.

Code:
```javascript
async function craftCraftingTable(bot) {
  // Check if we have spruce logs
  const spruceLog = bot.inventory.findInventoryItem(mcData.itemsByName["spruce_log"].id);
  if (!spruceLog) {
    bot.chat("I need spruce logs to craft a crafting table.");
    return;
  }

  // Craft 4 spruce planks from 1 spruce log (2x2 recipe)
  const planksRecipe = bot.recipesFor(mcData.itemsByName["spruce_planks"].id, null, 1, null)[0];
  if (!planksRecipe) {
    bot.chat("Cannot find recipe for spruce planks.");
    return;
  }
  await bot.craft(planksRecipe, 1, null); // craft 1 set (4 planks)
  bot.chat("Crafted 4 spruce planks.");

  // Now craft a crafting table from 4 planks (2x2 recipe)
  const tableRecipe = bot.recipesFor(mcData.itemsByName["crafting_table"].id, null, 1, null)[0];
  if (!tableRecipe) {
    bot.chat("Cannot find recipe for crafting table.");
    return;
  }
  await bot.craft(tableRecipe, 1, null);
  bot.chat("Crafted a crafting table.");
}
