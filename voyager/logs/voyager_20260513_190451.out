Code:
```javascript
async function mineWoodLogs(bot) {
  // Count existing logs
  let logCount = bot.inventory.items()
    .filter(item => item.name.endsWith("_log"))
    .reduce((sum, item) => sum + item.count, 0);
  if (logCount >= 4) {
    bot.chat("Already have 4 wood logs.");
    return;
  }

  // Explore to find a log block
  const directions = [
    new Vec3(1, 0, 1), new Vec3(-1, 0, 1), new Vec3(1, 0, -1), new Vec3(-1, 0, -1),
    new Vec3(1, 0, 0), new Vec3(-1, 0, 0), new Vec3(0, 0, 1), new Vec3(0, 0, -1)
  ];
  const direction = directions[Math.floor(Math.random() * directions.length)];
  bot.chat(`Exploring for trees in direction ${direction}`);
  const logBlock = await exploreUntil(bot, direction, 60, () => {
    return bot.findBlock({
      matching: block => block.name.endsWith("_log"),
      maxDistance: 32
    });
  });
  if (!logBlock) {
    bot.chat("Could not find any tree.");
    return;
  }

  const logType = logBlock.name;
  const needed = 4 - logCount;
  bot.chat(`Found ${logType}, mining ${needed} more logs.`);
  await mineBlock(bot, logType, needed);
  bot.chat("Successfully collected 4 wood logs.");
}
