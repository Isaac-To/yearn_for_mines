# ─── Minecraft Server ───────────────────────────────────────────────
# Connection settings for the Minecraft server the bot will join.
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=YearnForMines
MC_VERSION=1.21.4
MC_AUTH=offline

# ─── MCP Server ────────────────────────────────────────────────────
# Settings for the MC MCP server that exposes bot actions as MCP tools.
MCP_PORT=3000
MCP_HOST=0.0.0.0

# ─── Agent ─────────────────────────────────────────────────────────
# Behavior settings for the autonomous agent loop.
AGENT_GOAL=Find a tree and gather wood
AGENT_MAX_ITERATIONS=100
AGENT_MAX_RETRIES=3
AGENT_MAX_OBSERVATION_TOKENS=2000
AGENT_ENABLE_VLM=false
AGENT_LOOP_DELAY_MS=500

# ─── LLM ───────────────────────────────────────────────────────────
# OpenAI-compatible LLM endpoint. Defaults to Ollama.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_VISION_MODEL=
LLM_API_KEY=
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# ─── MemPalace ─────────────────────────────────────────────────────
# Optional: URL for the MemPalace MCP server for persistent memory.
# Leave empty to disable memory features.
MCP_MEMPALACE_URL=

# ─── Web UI ────────────────────────────────────────────────────────
# Settings for the debug dashboard web interface.
PORT=8080
MCP_MC_URL=http://localhost:3000/mcp