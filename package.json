{
  "name": "yearn-for-mines",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agentic system using MCP to control a Minecraft bot with MemPalace memory and local LLM",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "node scripts/dev-up-deps.mjs && pnpm --filter @yearn-for-mines/shared build && concurrently --names mcp,web,agent --prefix-colors cyan,green,magenta --kill-others-on-fail \"pnpm dev:mcp\" \"pnpm dev:web\" \"pnpm dev:agent\"",
    "dev:webstack": "node scripts/dev-up-deps.mjs && pnpm --filter @yearn-for-mines/shared build && concurrently --names mcp,web --prefix-colors cyan,green --kill-others-on-fail \"pnpm dev:mcp\" \"pnpm dev:web\"",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "dev:agent": "pnpm --filter agent dev",
    "dev:mcp": "pnpm --filter mc-mcp-server dev",
    "dev:mempalace": "docker compose -f docker/docker-compose.yml up mempalace",
    "dev:web": "pnpm --filter web-ui dev",
    "start:agent": "pnpm --filter agent start",
    "start:mcp": "pnpm --filter mc-mcp-server start",
    "start:web": "pnpm --filter web-ui start",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "dev:minecraft": "docker compose -f docker/docker-compose.yml up minecraft-server -d",
    "docker:reset": "docker compose -f docker/docker-compose.yml down -v",
    "postinstall": "node scripts/ensure-env.mjs",
    "dev:all": "pnpm run dev:webstack",
    "dev:all:agent": "pnpm run dev"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript-eslint": "^8.58.2"
  }
}